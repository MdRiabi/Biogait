# Copier vers .env et adapter.

# --- Production / dev avec Docker (app sur l’hôte, DB dans Docker) ---
DATABASE_URL=postgresql+asyncpg://biogait:biogaitsecret@127.0.0.1:5432/biogait
REDIS_URL=redis://127.0.0.1:6379/0

# --- Si l’application tourne dans le même docker-compose que Postgres ---
# DATABASE_URL=postgresql+asyncpg://biogait:biogaitsecret@db:5432/biogait
# REDIS_URL=redis://redis:6379/0

# --- Secours sans Postgres ---
# DATABASE_URL=sqlite+aiosqlite:///./biogait.db

SECRET_KEY=change-me-in-production
DEBUG=False

# Tests pytest : base biogait_test (créée au 1er docker compose si volume neuf).
# Volume Postgres déjà existant sans cette base :
#   docker exec -it biogait-db psql -U biogait -d biogait -c "CREATE DATABASE biogait_test;"
